# ChessEver — contributor environment template
#
#   cp .env.example .env
#
# Everything filled in below is a PUBLIC key that already ships inside every
# released App Store / Play Store build, so distributing it here leaks nothing.
# These keys let the app build, sign in, and read public broadcast data.
#
# They are not a path to abusing our data: the database is protected by
# row-level security, and the large historical game database is reached only
# through a separate, rate-limited API gated by GAMEBASE_API_KEY (see below).
#
# Generate your personal GAMEBASE_API_KEY at:  https://chessever.com/developers

# --- Public, prefilled (safe to use as-is) -----------------------------------

SUPABASE_URL=https://oelbsuggrzyqwzmvidju.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9lbGJzdWdncnp5cXd6bXZpZGp1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDk5MDgyODYsImV4cCI6MjA2NTQ4NDI4Nn0.YpIEGIVCN2yUmh4ALnuF0i4jKI3ld1VHNVSCN2J7R30

GOOGLE_WEB_CLIENT_ID=882734779574-4pttdbmj67d2044ag6kcq9n3rsao6k29.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=882734779574-8v68and9jcueedkvk0dl2ftse6dn8kt3.apps.googleusercontent.com

# Public RevenueCat SDK key (designed to live in the client). Purchases run
# against the store sandbox in local dev.
RevenueCatAPIKey=goog_ZmINjxirbMFvSsVMUfviZwrpfBY

# --- Your personal developer key ---------------------------------------------

# Historical game search and the position explorer go through the rate-limited
# Gamebase API. Leave this BLANK to run the app on bundled sample data, or
# generate a free, personal, rate-limited key at:
#   https://chessever.com/developers
GAMEBASE_API_KEY=

# --- Optional: analytics / crash / attribution -------------------------------
# Leave blank in local dev so your activity does not pollute production
# dashboards. The app runs fine without them.

SENTRY_FLUTTER=
AMPLITUDE=
CLARITY_PROJECT_ID=
ONESIGNAL_APP_ID=
APPSFLYER_DEV_KEY=

# Keep background workers off for local development.
DISABLE_WORKERS=true
